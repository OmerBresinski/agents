# Railway project ID
RAILWAY_PROJECT_ID=

# SSH public key for accessing agents (auto-filled by setup.sh)
SSH_AUTHORIZED_KEYS=

# SSH password for multi-device access
SSH_PASSWORD=

# AWS Bedrock authentication (bearer token) - optional
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=

# Bastion host (set after Railway deployment by ssh-setup.sh)
# VITE_BASTION_HOST=bastion-xxxx.up.railway.app

# Railway Bucket credentials (auto-set by deploy.sh -- do not edit manually)
# These are S3-compatible credentials for workspace sync and session persistence
BUCKET_ENDPOINT=
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=
BUCKET_NAME=
BUCKET_REGION=
