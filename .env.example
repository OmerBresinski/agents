# SSH public key for accessing agents
# Generate with: ./scripts/generate-keys.sh
SSH_AUTHORIZED_KEYS=

# AWS Bedrock authentication (bearer token)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=

# Bastion host (set after Railway deployment)
# VITE_BASTION_HOST=bastion-xxxx.up.railway.app
